{
    "name": "lapisense/php-client",
    "description": "Generic PHP client for the Lapisense licensing API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "Lapisense\\PHPClient\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "squizlabs/php_codesniffer": "^3.13",
        "phpmd/phpmd": "^2.15"
    }
}
