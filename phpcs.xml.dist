<?xml version="1.0"?>
<ruleset name="Lapisense PHP Client">
    <description>PSR-12 coding standard for Lapisense PHP Client</description>
    <rule ref="PSR12"/>
    <rule ref="PHPCompatibility"/>

    <config name="testVersion" value="7.4-"/>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
</ruleset>
